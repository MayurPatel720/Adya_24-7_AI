# ─── MiMo AI (your OpenRouter key) ───
XIAOMI_API_KEY=sk-or-v1-your-key-here

# ─── OpenClaw Gateway ───
OPENCLAW_GATEWAY_TOKEN=adyawear-openclaw-2026-secure
OPENCLAW_PORT=3001

# ─── Webhook Security ───
WEBHOOK_SECRET=adyawear_bridge_secret_2026

# ─── WhatsApp Config ───
WHATSAPP_BUSINESS_NAME=ADYAWEAR
WHATSAPP_SENDER_PHONE=+91XXXXXXXXXX

# ─── Admin ───
ADMIN_PHONE=+91XXXXXXXXXX
ADMIN_API_KEY=adyawear_admin_2026

# ─── ADYAWEAR Store ───
ADYAWEAR_STORE_URL=https://www.adyawear.in
ADYAWEAR_STORE_API=https://www.adyawear.in/api

# ─── Cron ───
FOLLOWUP_DELAY_DAYS=3
REVIEW_REQUEST_DELAY_DAYS=5

# ─── Server ───
PORT=3000
NODE_ENV=production
