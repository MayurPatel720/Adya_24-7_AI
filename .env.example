# OpenClaw Gateway
OPENCLAW_GATEWAY_URL=http://localhost:3001
OPENCLAW_GATEWAY_TOKEN=your_openclaw_gateway_token

# Webhook Security (shared with ADYAWEAR store)
WEBHOOK_SECRET=adyawear_whatsapp_bridge_2026

# WhatsApp Config
WHATSAPP_BUSINESS_NAME=ADYAWEAR
WHATSAPP_SENDER_PHONE=+91XXXXXXXXXX

# Admin
ADMIN_PHONE=+91XXXXXXXXXX
ADMIN_API_KEY=your_admin_api_key_here

# ADYAWEAR Store
ADYAWEAR_STORE_URL=https://www.adyawear.in
ADYAWEAR_STORE_API=https://www.adyawear.in/api

# Cron (days after delivery)
FOLLOWUP_DELAY_DAYS=3
REVIEW_REQUEST_DELAY_DAYS=5

# Server
PORT=3000
NODE_ENV=production
